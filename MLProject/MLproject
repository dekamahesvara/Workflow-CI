name: telco_churn_ci

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      input: {type: str, default: "namadataset_preprocessing"}
      n_estimators: {type: int, default: 100}
      max_depth: {type: int, default: 10}
    command: "python modelling.py --input {input} --n_estimators {n_estimators} --max_depth {max_depth}"
